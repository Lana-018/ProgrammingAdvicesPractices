-- Problem 16: Get all Makes that manufactures DriveTypeName = FWD
	select distinct Makes.Make,DriveTypes.DriveTypeName 
	from VehicleDetails 
	join Makes on VehicleDetails.MakeID=Makes.MakeID
	join DriveTypes on VehicleDetails.DriveTypeID=DriveTypes.DriveTypeID
	where DriveTypeName like 'FWD' order by Make;

-- Problem 17: Get total Makes that Mantufactures DriveTypeName=FWD
	select count(*) as TotalMakesManufacture_FWD_DriveType 
    from (select distinct Makes.Make from VehicleDetails 
	join Makes on VehicleDetails.MakeID=Makes.MakeID
	join DriveTypes on VehicleDetails.DriveTypeID=DriveTypes.DriveTypeID
	where DriveTypeName like 'FWD') as Result ;

-- Problem 18: Get total vehicles per DriveTypeName Per Make and order them per make asc then per total Desc
   	select Makes.Make,DriveTypes.DriveTypeName,count(*) as TotalNumberOfVehicles
	from VehicleDetails 
	join Makes on VehicleDetails.MakeID=Makes.MakeID
	join DriveTypes on VehicleDetails.DriveTypeID=DriveTypes.DriveTypeID
	group by  DriveTypes.DriveTypeName,Make
	order by Make, TotalNumberOfVehicles desc;

-- Problem 19: Get total vehicles per DriveTypeName Per Make then filter only results with total > 10,000
	select Makes.Make,DriveTypes.DriveTypeName,count(*) as TotalNumberOfVehicles
	from VehicleDetails 
	join Makes on VehicleDetails.MakeID=Makes.MakeID
	join DriveTypes on VehicleDetails.DriveTypeID=DriveTypes.DriveTypeID
	group by  DriveTypes.DriveTypeName,Make having count(*)>10000 
	order by Make, TotalNumberOfVehicles desc;

